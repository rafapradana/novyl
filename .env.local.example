# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to browser
# Used for: admin operations, account deletion cascade, Mem0 cleanup
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (for LangGraph checkpointer, pgvector queries)
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
